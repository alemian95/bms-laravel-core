# ================================================================
# bms-core — variabili d'ambiente di produzione
#
# In Coolify: queste variabili vanno inserite nel tab "Environment
# Variables" della risorsa, NON in un file .env sul disco.
# Questo file serve solo come riferimento e per deploy locali con
# `docker compose --env-file deploy/.env.production up -d`.
# ================================================================

# ----------- Laravel core -----------
APP_NAME=bms-core
APP_ENV=production
# Genera con:  php artisan key:generate --show
APP_KEY=
APP_DEBUG=false
APP_URL=https://bms.example.com
APP_LOCALE=it
APP_FALLBACK_LOCALE=en

LOG_LEVEL=info

# ----------- Database (PostgreSQL) -----------
DB_DATABASE=bms_core
DB_USERNAME=bms_core
# Password forte, minimo 24 caratteri
DB_PASSWORD=

# ----------- Driver (tutti su database finché non introduci Redis) -----------
CACHE_STORE=database
SESSION_DRIVER=database
SESSION_LIFETIME=120
QUEUE_CONNECTION=database

# ----------- Meilisearch -----------
# Key casuale, minimo 32 byte (openssl rand -hex 32)
MEILISEARCH_KEY=

# ----------- Mail (opzionale; default 'log' scarta le mail in storage/logs) -----------
MAIL_MAILER=log
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=no-reply@example.com

# ----------- Toggle di deploy -----------
# Il container `app` esegue php artisan migrate --force al boot se true
APP_RUN_MIGRATIONS=true
# Il container `app` sincronizza le index settings di Scout al boot se true
APP_SCOUT_SYNC=true
